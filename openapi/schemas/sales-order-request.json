{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sales Order Request",
  "type": "object",
  "required": ["externalOrderId", "soldToParty", "items"],
  "properties": {
    "externalOrderId": { "type": "string" },
    "sourceSystem": { "type": "string" },
    "soldToParty": { "type": "string" },
    "shipToParty": { "type": "string" },
    "purchaseOrderByCustomer": { "type": "string" },
    "requestedDeliveryDate": { "type": "string", "format": "date" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["lineNumber", "material", "quantity", "unitOfMeasure"],
        "properties": {
          "lineNumber": { "type": "string" },
          "material": { "type": "string" },
          "quantity": { "type": "number", "exclusiveMinimum": 0 },
          "unitOfMeasure": { "type": "string" },
          "plant": { "type": "string" },
          "requestedDeliveryDate": { "type": "string", "format": "date" }
        }
      }
    }
  }
}
