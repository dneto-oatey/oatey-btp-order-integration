  "item": [
    {
      "name": "Happy Path - Minimal SAP Sales Order JSON",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-Correlation-ID",
            "value": "poc-correlation-001",
            "type": "text"
          },
          {
            "key": "Idempotency-Key",
            "value": "poc-idempotency-001",
            "type": "text"
          },
          {
            "key": "X-Consumer-ID",
            "value": "{{consumerId}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"SalesOrderType\": \"OR\",\n  \"SalesOrganization\": \"1000\",\n  \"DistributionChannel\": \"10\",\n  \"OrganizationDivision\": \"00\",\n  \"SoldToParty\": \"476272\",\n  \"PurchaseOrderByCustomer\": \"POC-POSTMAN-001\",\n  \"to_Item\": {\n    \"results\": [\n      {\n        \"Material\": \"MAT-001\",\n        \"RequestedQuantity\": \"1\",\n        \"to_PricingElement\": {\n          \"results\": [\n            {\n              \"ConditionType\": \"PR00\",\n              \"ConditionRateValue\": \"10.00\",\n              \"ConditionCurrency\": \"USD\"\n            }\n          ]\n        }\n      }\n    ]\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{runtimeBaseUrl}}/sales-orders",
          "host": [
            "{{runtimeBaseUrl}}"
          ],
          "path": [
            "sales-orders"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 202', function () { pm.response.to.have.status(202); });",
              "pm.test('correlationId returned', function () { pm.expect(pm.response.json().correlationId).to.exist; });"
            ]
          }
        }
      ]
    },
